# ==========================================
# Entorno: RG Contratos — API NestJS
# Copiar a .env y ajustar valores locales
# ==========================================

NODE_ENV=development
PORT=3000

# CORS — orígenes permitidos (separados por coma, sin espacios obligatorios)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL (docker compose publica 5433 → 5432 del contenedor)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=rguser
DB_PASSWORD=rgpassword
DB_NAME=rg_contracts
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=true

# JWT (cambiar JWT_SECRET en producción)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# URL base del frontend (enlaces en correos de auth)
APP_URL=http://localhost:3000

# Resend — dejar vacío en local si no se envían correos
RESEND_API_KEY=
RESEND_FROM=no-reply@example.com
