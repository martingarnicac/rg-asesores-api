<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #f4f6f8;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 40px auto;
      background: #ffffff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      overflow: hidden;
    }
    .header {
      background: {{headerColor}};
      color: #fff;
      padding: 28px 24px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 22px;
      font-weight: 600;
    }
    .content {
      padding: 32px 28px;
      color: #333;
      line-height: 1.6;
    }
    .content p {
      margin: 0 0 16px;
    }
    .footer {
      padding: 20px 28px;
      font-size: 12px;
      color: #888;
      text-align: center;
      background: #fafafa;
      border-top: 1px solid #eee;
    }
  </style>
</head>
<body>
  <div class="container">
    {{> header}}
    <div class="content">
      {{{body}}}
    </div>
    {{> footer}}
  </div>
</body>
</html>
